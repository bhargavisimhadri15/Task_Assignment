# Local MongoDB (recommended)
MONGO_URL=mongodb://localhost:27017
DB_NAME=task_assignment

# Server
PORT=8001
# Comma-separated list, e.g. http://localhost:3000,https://yourdomain.com
CORS_ORIGINS=*

# Auth
JWT_SECRET=change_me_to_a_long_random_string

# Optional: set to "true" when serving API over HTTPS and using cross-site cookies
# COOKIE_SECURE=true

# Optional seed users (dev only)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

DEMO_EMAIL=demo@example.com
DEMO_PASSWORD=demo123
DEMO_NAME=Demo User

# Dev-only: return reset token in API response (no email configured)
RETURN_RESET_TOKEN=1

# Optional: if local Mongo isn't reachable, backend can start an embedded MongoDB
# USE_MONGODB_MEMORY=1

